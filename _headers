# Cloudflare Pages _headers — ported from vercel.json (samedayjetwash.com)
# CF applies ALL matching blocks cumulatively; list specific paths before the /* catch-all.

/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://eu.i.posthog.com https://eu-assets.i.posthog.com https://api.web3forms.com; script-src 'self' 'unsafe-inline' https://eu-assets.i.posthog.com; worker-src 'self' blob:; img-src 'self' data: https://eu-assets.i.posthog.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; object-src 'none'; base-uri 'self'; form-action 'self' https://api.web3forms.com
